correct_pin = "1234"
current_balance = 1000.00

# PIN verification
while True:
    entered_pin = input("Please enter your 4-digit PIN: ")
    if entered_pin == correct_pin:
        print("PIN accepted. Welcome to the ATM!")
        break
    else:
        print("Incorrect PIN. Please try again.")
while True:
    print("\n--- ATM Menu ---")
    print("1. Check Balance")
    print("2. Deposit")
    print("3. Withdraw")
    print("4. Exit")

    choice = input("Enter your choice (1-4): ")

    if choice == '1':
        print(f"Your current balance is: ${current_balance:.2f}")
    elif choice == '2':
        try:
            deposit_amount = float(input("Enter amount to deposit: $"))
            if deposit_amount > 0:
                current_balance += deposit_amount
                print(f"${deposit_amount:.2f} deposited successfully. New balance: ${current_balance:.2f}")
            else:
                print("Deposit amount must be positive.")
        except ValueError:
            print("Invalid input. Please enter a numerical amount.")
    elif choice == '3':
        try:
            withdraw_amount = float(input("Enter amount to withdraw: $"))
            if withdraw_amount > 0:
                if current_balance >= withdraw_amount:
                    current_balance -= withdraw_amount
                    print(f"${withdraw_amount:.2f} withdrawn successfully. New balance: ${current_balance:.2f}")
                else:
                    print("Insufficient balance.")
            else:
                print("Withdrawal amount must be positive.")
        except ValueError:
            print("Invalid input. Please enter a numerical amount.")
    elif choice == '4':
        print("Thank you for using the ATM. Goodbye!")
        break
    else:
        print("Invalid choice. Please select a number between 1 and 4.")
