import re

# Get paragraph input from the user
paragraph = input("Please enter a paragraph: ")
# Clean and prepare the text
# Convert to lowercase to handle case-insensitivity for vowels and word comparison
cleaned_paragraph = paragraph.lower()

# Remove punctuation and split into words
# Use regex to find all alphabetic sequences (words)
words = re.findall(r'\b[a-z]+\b', cleaned_paragraph)

# Count total words
total_words = len(words)
print(f"Total words: {total_words}")
# Find the longest word
longest_word = ""
if words:
    for word in words:
        if len(word) > len(longest_word):
            longest_word = word
    print(f"Longest word: '{longest_word}' (length: {len(longest_word)})")
else:
    print("No words found to determine the longest word.")
# Count vowels
vowels = "aeiou"
vowel_count = 0
for char in cleaned_paragraph:
    if char in vowels:
        vowel_count += 1

print(f"Total vowels: {vowel_count}")
